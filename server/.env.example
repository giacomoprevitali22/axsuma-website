# Stripe API Keys (Test Mode)
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Webhook Secret (for payment confirmations)
# Get this from https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Price IDs (create in Dashboard > Products)
STRIPE_PRICE_INDIVIDUAL=price_XXXXXXXX
STRIPE_PRICE_CORPORATE=price_XXXXXXXX

# Server
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000